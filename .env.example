# ─────────────────────────────────────────────────────────────────────────────
# UIWiz — Docker Compose environment template
# Copy this file to .env and fill in all values before running docker compose.
#
#   cp .env.example .env
#
# These variables are read by docker-compose at BUILD time and passed as build
# args to the Next.js image.  NEXT_PUBLIC_* values are compiled into the JS
# bundle — changing them requires rebuilding the frontend image.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend URL (where the FastAPI server is reachable from the browser) ──────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Firebase project config ───────────────────────────────────────────────────
# Find these in Firebase console → Project settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# ── SEO canonical URL (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com
